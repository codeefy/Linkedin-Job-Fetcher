name: Update Data

on:
  workflow_dispatch:
    inputs:
      job_title:
        description: 'Job role to scrape (leave empty to scrape all default roles)'
        required: false
        default: ''
      location:
        description: 'Location'
        required: false
        default: 'India'
  schedule:
    - cron: '0 2 * * *' # runs once daily at 2AM UTC (7:30AM IST)

jobs:
  build:
    runs-on: ubuntu-latest
    steps:

      - name: Checkout repo
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GH_TOKEN }}
          persist-credentials: true

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Chrome
        uses: browser-actions/setup-chrome@v1
        with:
          chrome-version: stable

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run scraper (specific role if provided, else all default roles)
        run: |
          if [ -n "${{ github.event.inputs.job_title }}" ]; then
            echo "Scraping specific role: ${{ github.event.inputs.job_title }}"
            python main.py "${{ github.event.inputs.job_title }}" "${{ github.event.inputs.location }}"
          else
            echo "No role specified — scraping all default roles"
            python main.py
          fi

      - name: Commit changes
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add -A
          git diff-index --quiet HEAD || git commit -m "updated data Co-authored-by: codeefy"

      - name: Push changes
        uses: ad-m/github-push-action@v0.8.0
        with:
          github_token: ${{ secrets.GH_TOKEN }}
          branch: main
          repository: codeefy/linkedin-job-fetcher